# =============================================================================
# SDR Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# --- Apollo.io (contact enrichment) ---
APOLLO_API_KEY=your_apollo_api_key_here

# --- Apify (Google Maps scraping) ---
APIFY_API_TOKEN=your_apify_token_here

# --- CRM ---
CRM_BASE_URL=https://your-crm-url.com
CRM_API_KEY=your_crm_api_key_here

# --- Gmail OAuth2 ---
# credentials.json must be downloaded from Google Cloud Console
# token.json is generated automatically after first auth
# Account email used for outreach:
GMAIL_ACCOUNT=your.email@company.com

# --- Optional: Other integrations ---
# COMPOSIO_API_KEY=your_composio_key_here
# HUNTER_API_KEY=your_hunter_key_here
